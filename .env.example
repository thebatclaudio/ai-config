# =============================================================================
# ai-config — environment template
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
# Never commit `.env` — it is git-ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
GOOGLE_API_KEY=replace-me

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# Absolute path to THIS ai-config repository on disk.
# This value is injected wherever the template references {{BASE_PROJECT_PATH}}.
# Example (Linux/macOS): /home/user/Projects/ai-config
# Example (Windows):     C:/Users/user/Projects/ai-config
BASE_PROJECT_PATH=/absolute/path/to/ai-config

# -----------------------------------------------------------------------------
# OpenCode runtime (optional)
# -----------------------------------------------------------------------------
# Override the OpenCode config directory. Leave blank to use the platform default:
#   Linux/macOS: ~/.config/opencode
#   Windows:     %APPDATA%\opencode
OPENCODE_CONFIG_DIR=
